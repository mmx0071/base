# PR 示例：在基线 Dockerfile 上增加 tree（合并进主 Dockerfile 即 PR diff）
FROM ubuntu:22.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 ca-certificates tree \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY serve.py /app/serve.py

EXPOSE 8080
CMD ["python3", "/app/serve.py"]
